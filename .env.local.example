# Supabase（公開キー - フロントエンドから使用可）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase（サービスロールキー - サーバーサイドのみ）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Price IDs（Stripeダッシュボードで商品・Priceを作成後に設定）
NEXT_PUBLIC_STRIPE_PRICE_LOGO_REMOVE=price_...
NEXT_PUBLIC_STRIPE_PRICE_LUXURY_BLACK=price_...
NEXT_PUBLIC_STRIPE_PRICE_GLASS_PREMIUM=price_...
NEXT_PUBLIC_STRIPE_PRICE_NEON_GLOW=price_...
NEXT_PUBLIC_STRIPE_PRICE_ANIMATED_AURORA=price_...

# アプリURL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# バックエンド用（Webhook・Checkout redirect先）
NEXT_PUBLIC_SITE_URL=http://localhost:3000
